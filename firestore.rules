rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role Helpers (Looking up role in users collection)
    function getUserData(email) {
      return get(/databases/$(database)/documents/users/$(email)).data;
    }
    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.token.email).role == role;
    }
    function isAdmin() { return hasRole('admin'); }
    function isTeacher() { return hasRole('teacher'); }
    function isStudent() { return hasRole('student'); }
    function isOwner(email) { return isSignedIn() && request.auth.token.email == email; }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'name']) &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['admin', 'teacher', 'student'] &&
             data.name is string && data.name.size() <= 100;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['email', 'name']) &&
             data.email is string && data.name is string;
    }

    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collection Rules ---

    match /users/{email} {
      allow read: if isSignedIn() && (isOwner(email) || isAdmin());
      allow create: if isSignedIn() && isValidUser(incoming()) && (isOwner(email) || isAdmin());
      allow update: if isSignedIn() && isValidUser(incoming()) && (
        isAdmin() || 
        (isOwner(email) && incoming().role == existing().role) // Users can't change their own role
      );
    }

    match /students/{email} {
      allow read: if isSignedIn() && (isOwner(email) || isAdmin() || isTeacher());
      allow write: if isSignedIn() && (isAdmin() || isTeacher() || isOwner(email));
    }

    match /teachers/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if isSignedIn() && (isOwner(existing().studentEmail) || isAdmin() || isTeacher());
      allow create: if isSignedIn() && (isOwner(incoming().studentEmail) || isAdmin());
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Interaction Collections (if any, like test logs)
    match /test_collection/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
